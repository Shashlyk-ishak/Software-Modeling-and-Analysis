<Window x:Class="LIFT.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LIFT"
        mc:Ignorable="d"
        Title="Лифт" Height="450" Width="800" ResizeMode="NoResize">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
            <ColumnDefinition></ColumnDefinition>
        </Grid.ColumnDefinitions>


        <Button Name="Floor_1" Width="25" Height="25" Content="1" Grid.Column="0" Grid.Row="2" Click="Floor_1_Click"/>
        <Button Name="Floor_2" Width="25" Height="25" Content="2" Grid.Column="0" Grid.Row="1" Click="Floor_2_Click"/>
        <Button Name="Floor_3" Width="25" Height="25" Content="3" Grid.Column="0" Grid.Row="0" Click="Floor_3_Click"/>
        <Button Name="Open_cabin"  Width="150" Height="50"  Content="Открыть двери" Grid.Column="2" Grid.Row="0" Background="LawnGreen" Click="Open_cabin_Click"/>
        <Button Name="Close_cabin" Width="150" Height="50"  Content="Закрыть двери" Grid.Column="2" Grid.Row="2" Background="Red" Click="Close_cabin_Click"/>

        <Image x:Name="Cabin_image" Grid.Column="1" HorizontalAlignment="Left" Height="82"  Grid.Row="2" VerticalAlignment="Top" Width="64" Margin="92,29,0,0" Source="/Closed_doors.png" Stretch="Fill">
            <Image.RenderTransform>
                <TranslateTransform x:Name="CabinTransform" Y="0"/>
            </Image.RenderTransform>
        </Image>


    </Grid>
</Window>
